rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User Profiles
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);
      // Only server (Admin SDK) should update access rights, 
      // but we allow users to update their own display name if needed
      allow update: if isOwner(userId) && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['hasAccessPsychology', 'hasAccessCameleon', 'hasAccessAlgo', 'isAlgoUser']);
      allow create: if isOwner(userId);
    }

    // Formation Tokens
    match /formation_tokens/{token} {
      // Tokens are read by the frontend to grant temporary access
      // We allow reading if the token exists and is not expired (handled in app logic)
      // For security, we could restrict to the user's email if we store it in the token
      allow read: if true; 
      allow write: if false; // Only server can create/delete tokens
    }
    
    // Health Check
    match /health_check/{docId} {
      allow read, write: if true;
    }
  }
}
