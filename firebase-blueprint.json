{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user access rights and profile information.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "hasAccessPsychology": { "type": "boolean" },
        "hasAccessCameleon": { "type": "boolean" },
        "hasAccessAlgo": { "type": "boolean" },
        "isAlgoUser": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "formation_tokens": {
      "title": "Formation Access Token",
      "description": "Temporary tokens for direct video access.",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "userEmail": { "type": "string" },
        "formationId": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile document."
    },
    "/formation_tokens/{token}": {
      "schema": "formation_tokens",
      "description": "Access token for a formation."
    }
  }
}
