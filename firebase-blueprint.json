{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "isProfessional": { "type": "boolean" },
        "isFeaturedPro": { "type": "boolean" },
        "featuredProPriority": { "type": "number" },
        "featuredProPosition": { "type": "string" },
        "featuredProActive": { "type": "boolean" },
        "isVerified": { "type": "boolean" },
        "recommendations": { "type": "number" },
        "pushNotificationsEnabled": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "lastSeenAt": { "type": "string", "format": "date-time" },
        "isPhoneVerified": { "type": "boolean" },
        "responseRate": { "type": "string" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review after an exchange",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adId": { "type": "string" },
        "reviewerId": { "type": "string" },
        "reviewerName": { "type": "string" },
        "targetUserId": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["adId", "reviewerId", "targetUserId", "rating", "comment", "createdAt"]
    },
    "Ad": {
      "title": "Ad",
      "description": "Classified advertisement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["offer", "seek"] },
        "price": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "zipCode": { "type": "string" }
          }
        },
        "details": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "sold", "deleted"] },
        "duplicateHash": { "type": "string", "description": "Hash of title + description + authorId to prevent duplicates" },
        "userName": { "type": "string" },
        "authorIsVerified": { "type": "boolean" },
        "isFeatured": { "type": "boolean" },
        "featuredPriority": { "type": "number" },
        "featuredPosition": { "type": "number" },
        "featuredActive": { "type": "boolean" }
      },
      "required": ["authorId", "title", "category", "location", "duplicateHash"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat between two users about an ad",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adId": { "type": "string" },
        "adTitle": { "type": "string" },
        "adImage": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastSenderId": { "type": "string" },
        "lastSenderName": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "object", "description": "Map of userId to unread message count" }
      },
      "required": ["adId", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "audioUrl": { "type": "string", "description": "URL to the voice message audio file" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["conversationId", "senderId"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A user's favorite advertisement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "adId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "adId"]
    },
    "Banner": {
      "title": "Banner",
      "description": "An advertising banner",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "linkUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "imageUrl", "linkUrl", "isActive", "createdAt"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "A message sent via the contact form",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string", "description": "Optional userId if the user is logged in" }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Classified advertisements"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Chat conversations"
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    },
    "/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "User favorite ads"
    },
    "/contact_messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Messages from the contact form"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "User reviews"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Advertising banners"
    }
  }
}
